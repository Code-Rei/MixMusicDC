# ================================
# Discord Bot Configuration
# ================================
# Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# For guild-specific command deployment during development (optional)
GUILD_ID=your_test_server_id_here

# ================================
# Spotify API (for Spotify support)
# ================================
# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ================================
# Genius API (for Lyrics)
# ================================
# Get from https://genius.com/api-clients
GENIUS_API_KEY=your_genius_api_key_here

# ================================
# Server Configuration
# ================================
# Port for the keep-alive Express server (Render sets this automatically)
PORT=3000

# Your Render app URL (used for self-ping keep-alive)
# Example: https://mixmusicdc.onrender.com
RENDER_URL=https://your-app-name.onrender.com
